{
  "version": 2,
  "cleanUrls": false,
  "trailingSlash": false,
  "routes": [
    {
      "src": "^/$",
      "dest": "/index.html"
    },
    {
      "src": "^/preview$",
      "dest": "/preview.html"
    },
    {
      "src": "^/preview-batch$",
      "dest": "/preview-batch.html"
    },
    {
      "src": "^/preview-import$",
      "dest": "/preview-import.html"
    },
    {
      "src": "^/final$",
      "dest": "/ProjectMemberImport-final.html"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
